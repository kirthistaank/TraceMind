# OpenAI Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Neo4j Configuration (optional - for knowledge graph)
# NEO4J_URI_KGA=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USERNAME_KGA=neo4j
# NEO4J_PASSWORD_KGA=your-password
# NEO4J_DATABASE_KGA=neo4j

# CareTrace Behavior Flags
CARETRACE_MOCK_LLM=0
CARETRACE_SKIP_NEO4J=1
CARETRACE_EXIT_ON_COMPLETE=1
CARETRACE_USE_LAG=0
